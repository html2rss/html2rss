#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

if command -v mise >/dev/null 2>&1; then
  exec mise exec -- bundle exec ruby -e 'require "rubocop"; argv = %w[--cache false] + ARGV; exit RuboCop::CLI.new.run(argv)' -- "$@"
fi

exec bundle exec ruby -e 'require "rubocop"; argv = %w[--cache false] + ARGV; exit RuboCop::CLI.new.run(argv)' -- "$@"
